# Copie este arquivo para .env e ajuste se necessário
# Nenhuma API key necessária — Ollama roda localmente

DATABASE_URL=sqlite:////app/data/translator.db
UPLOAD_DIR=./uploads
COVER_DIR=./covers
PAGES_DIR=./pages
MAX_CHUNK_CHARS=1800
TESSERACT_LANGUAGES=eng
CORS_ORIGINS=http://localhost:5173
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=translategemma
